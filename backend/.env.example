# ============ LOCAL ============
# Renombra a .env para desarrollo local
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-larga
DEBUG=True

DB_NAME=centro_mando
DB_USER=root
DB_PASSWORD=tu_password_mysql
DB_HOST=127.0.0.1
DB_PORT=3306

# ============ PRODUCCIÓN (Railway) ============
# NO uses .env en Railway; define estas variables en el panel de Railway:
#
#   SECRET_KEY=<clave-aleatoria-larga>
#   DEBUG=False
#   DATABASE_URL=<lo inyecta el plugin MySQL de Railway automáticamente>
#   ALLOWED_HOSTS=<tu-app.up.railway.app>
#   CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app
